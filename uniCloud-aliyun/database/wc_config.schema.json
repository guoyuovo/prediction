{
  "bsonType": "object",
  "description": "全局配置。put-payload 写入 payload 云存储 URL，co-data / live-rec 读取。",
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": { "description": "固定 payload" },
    "url": { "bsonType": "string", "description": "云存储 payload.json 公网 URL" },
    "fileID": { "bsonType": "string" },
    "updatedAt": { "bsonType": "timestamp" },
    "matches": { "bsonType": "int", "description": "场次数量" }
  }
}
