      "expert": {
        "name": "陈亦明",
        "avatar": "https://relottery.nosdn.127.net/user/20170921/3OnGYl.jpg",
        "slogan": "足坛名宿",
        "desc": "南派足球代表人物，足坛名宿，著名足球教练，曾任多家足球俱乐部总经理。",
        "hitRate": 0.83,
