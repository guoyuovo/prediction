      "expert": {
        "name": "乔瓦尼",
        "avatar": "https://relottery.ws.126.net/user/20190315/c33WA2.jpg",
        "slogan": "资深媒体人",
        "desc": "《体坛周报》驻意大利特约记者，研究比赛规律，对彩票有独特兴趣。",
        "hitRate": 0.67,
