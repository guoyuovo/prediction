      "expert": {
        "name": "李惠宁",
        "avatar": "https://relottery.ws.126.net/user/snapshot/20240619/mGady8X.jpg",
        "slogan": "足球分析师",
        "desc": "车模一枚！爱足球的软妹子！",
        "hitRate": 0.67,
