      "expert": {
        "name": "张家宾",
        "avatar": "https://relottery.ws.126.net/user/snapshot/20250703/B3zGyyy.jpg",
        "slogan": "足篮分析师",
        "desc": "实战玩家，足篮双修，只用红单说话！",
        "hitRate": 0.38,
        "recent": "近13场中5场",
        "follower": 719,
