      "expert": {
        "name": "刘胜",
        "avatar": "https://relottery.ws.126.net/user/snapshot/20251113/6xp1Znr.jpg",
        "slogan": "足篮分析师",
        "desc": "擅长挖掘和分析数据，多维度理论与实战结合",
