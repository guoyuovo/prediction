    {
      "threadId": 3506896,
      "title": "【西班牙VS奥地利】斗牛士会成为下一个爆冷对象吗？",
      "publishTime": "8小时前发布",
      "free": true,
      "price": 0,
      "previousPrice": 88,
      "type": "单场",
      "matchNum": 1,
      "matchZh": "西班牙 vs 奥地利",
      "home": "Spain",
