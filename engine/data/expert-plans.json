      "expert": {
        "name": "Jarkko",
        "avatar": "https://relottery.nosdn.127.net/user/20180710/kk2hSD.png",
        "slogan": "外籍分析师",
        "desc": "芬兰人，有自己投注模型，公开记录的2136场比赛场均盈利率超10%",
